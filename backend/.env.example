APP_ENV=local
# APP_DEBUG enables detailed error messages and stack traces in API responses.
# It should be set to false in production and only true during development.
# See backend/bootstrap/middleware.php for how this variable is used to toggle debug info.
APP_DEBUG=false
APP_TIMEZONE=Asia/Tokyo
APP_ORIGIN_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:8080

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=survey
DB_USER=mysqluser
DB_PASS=password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Mail (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME="Survey App"

# Mail (Resend)
# RESEND_API_KEY=

# LINE
LINE_CHANNEL_ID=
