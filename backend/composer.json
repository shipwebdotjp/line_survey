{
    "name": "app/backend",
    "description": "Backend for Survey App",
    "type": "project",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^11.0",
        "php-di/php-di": "^7.0",
        "robmorgan/phinx": "^0.16.5",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.13",
        "symfony/config": "^7.2",
        "symfony/console": "^7.2",
        "symfony/filesystem": "^7.2",
        "symfony/string": "^7.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true
    }
}
